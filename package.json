    "playwright",
    "typescript",
    "automation",
    "data-driven"
  ],
  "author": "sdahal",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}